PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret
USE_SSH_TUNNEL=true
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password

# SSH tunnel configuration
SSH_HOST=your-ssh-host
SSH_PORT=22
SSH_USER=your-ssh-user
SSH_PASSWORD=your-ssh-password
SSH_PRIVATE_KEY_PATH=
SSH_PASSPHRASE=
SSH_DST_HOST=127.0.0.1
SSH_DST_PORT=5432
SSH_LOCAL_HOST=127.0.0.1
SSH_LOCAL_PORT=55432
SSH_READY_TIMEOUT_MS=45000

# PostgreSQL connection through local forwarded port
PGHOST=127.0.0.1
PGPORT=55432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=replace-with-your-db-password
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=15000
